rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Schema Validations
    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             data.email is string &&
             (data.get('displayName', '') is string) &&
             (data.get('pregnancyStartDate', '') is string) &&
             (data.get('currentTrimester', 1) is int) &&
             data.keys().hasAll(['uid', 'email']) &&
             data.keys().size() >= 2;
    }

    function isValidJournal(data) {
      return data.userId == request.auth.uid &&
             data.content is string && data.content.size() <= 10000 &&
             data.timestamp is timestamp &&
             data.keys().hasAll(['userId', 'content', 'timestamp']);
    }

    function isValidReport(data) {
      return data.userId == request.auth.uid &&
             data.timestamp is timestamp &&
             data.keys().hasAll(['userId', 'timestamp']);
    }

    function isValidAlert(data) {
      return data.userId == request.auth.uid &&
             data.timestamp is timestamp &&
             data.keys().hasAll(['userId', 'timestamp']);
    }

    // Resources
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().uid == existing().uid &&
                    incoming().email == existing().email;

      match /journal/{entryId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidJournal(incoming());
        allow update: if isOwner(userId) && isValidJournal(incoming()) &&
                      incoming().userId == existing().userId;
        allow delete: if isOwner(userId);
      }

      match /reports/{reportId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidReport(incoming());
        allow update: if isOwner(userId) && isValidReport(incoming()) &&
                      incoming().userId == existing().userId;
        allow delete: if isOwner(userId);
      }

      match /alerts/{alertId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidAlert(incoming());
        allow update: if isOwner(userId) && isValidAlert(incoming()) &&
                      incoming().userId == existing().userId;
      }
    }
  }
}
